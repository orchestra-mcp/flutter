default_platform(:ios)

platform :ios do
  desc "Build release IPA"
  lane :build do
    setup_ci if ENV["CI"]

    Dir.chdir("../..") do
      sh("flutter", "build", "ipa", "--release")
    end
  end

  desc "Deploy to TestFlight"
  lane :deploy_testflight do
    build

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "../build/ios/ipa/Orchestra.ipa",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Promote to App Store"
  lane :deploy_appstore do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )

    deliver(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: false,
      automatic_release: false
    )
  end

  desc "Sync certificates and profiles (match)"
  lane :sync_certs do
    match(
      type: "appstore",
      app_identifier: "com.orchestramcp.orchestra",
      readonly: true
    )
  end
end
